{
  "name": "helldivers2-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing live Helldivers 2 galactic war data.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jiti": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@jest/globals": "^30.4.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.10",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "wrangler": "^4.92.0"
  },
  "license": "MIT"
}
